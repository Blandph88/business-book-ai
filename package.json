{
  "name": "business-book-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Business Book — local-first BD pipeline & network CRM. Import your LinkedIn connections, segment them by industry, function and seniority, and work the pipeline. Data stays in a file you own.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen-demo": "npx --yes tsx scripts/gen-demo.mts",
    "qa": "npx --yes tsx scripts/qa-ground-truth.mts",
    "router-coverage": "npx --yes tsx scripts/router-coverage.test.ts",
    "eval": "npx --yes tsx scripts/eval/run.mts",
    "eval:threads": "EVAL_SET=threads npx --yes tsx scripts/eval/run.mts",
    "eval:memory": "EVAL_SET=memory npx --yes tsx scripts/eval/run.mts",
    "eval:critical": "EVAL_SET=critical npx --yes tsx scripts/eval/run.mts",
    "eval:capability": "EVAL_SET=capability npx --yes tsx scripts/eval/run.mts",
    "eval:polish": "EVAL_SET=polish npx --yes tsx scripts/eval/run.mts",
    "eval:core": "EVAL_SET=core npx --yes tsx scripts/eval/run.mts"
  },
  "dependencies": {
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
